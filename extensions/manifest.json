{
  "manifest_version": 3,
  "name": "UC Remote Icon Library",
  "version": "1.0",
  "description": "Adds Icon library to the UC Web-Configurator.",
  "browser_specific_settings": {
    "gecko": {
      "id": "uc-icon-library@unfolded.tools",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": []
      }
    }
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://*/configurator/*",
    "https://api.unfolded.tools/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "UC Icon Library",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/configurator/*",
        "https://*/configurator/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
